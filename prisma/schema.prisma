generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Plan {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameEn      String
  nameAr      String
  briefEn     String
  briefAr     String
  priceMonthlyEgp String?
  priceQuarterlyEgp String?
  priceMonthlyUsd String?
  priceQuarterlyUsd String?
  salePriceMonthlyEgp String?
  salePriceQuarterlyEgp String?
  salePriceMonthlyUsd String?
  salePriceQuarterlyUsd String?
  featuresEn  String   // Stored as JSON string
  featuresAr  String   // Stored as JSON string
  videoUrl    String?
  isActive    Boolean  @default(true)
  isOnHold    Boolean  @default(false)
  followUpFrequency String? // 'monthly' | 'weekly' | 'daily'
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  purchases   Purchase[]
  reviews     Review[]
}

model FAQ {
  id         String   @id @default(cuid())
  questionEn String
  questionAr String
  answerEn   String
  answerAr   String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Policy {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g., 'privacy', 'refund', 'terms'
  titleEn     String
  titleAr     String
  contentEn   String   // Rich Text (HTML)
  contentAr   String   // Rich Text (HTML)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  type          String   // 'FIXED' or 'PERCENTAGE'
  value         Float
  totalLimit    Int?
  perUserLimit  Int?     @default(1)
  usageCount    Int      @default(0)
  isActive      Boolean  @default(true)
  appliesToAll  Boolean  @default(true)
  planIds       String[] // PostgreSQL support for string arrays
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  purchases     Purchase[]
}

model Purchase {
  id           String   @id @default(cuid())
  clientName   String
  email        String?
  whatsapp     String?
  planId       String
  plan         Plan     @relation(fields: [planId], references: [id])
  amount       Float
  currency     String
  status       String   @default("PENDING")
  invoiceId    String?  @unique
  invoiceKey   String?
  paymentMethod String?
  region       String?  // 'egypt' or 'global'
  notes        String?
  couponId     String?
  coupon       Coupon?  @relation(fields: [couponId], references: [id])
  discountAmount Float   @default(0)
  receiptUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Transformation {
  id          String   @id @default(cuid())
  nameEn      String
  nameAr      String
  age         Int?
  resultEn    String
  resultAr    String
  durationEn  String?
  durationAr  String?
  imagePath   String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id          String   @id @default(cuid())
  clientName  String
  rating      Int
  comment     String
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id])
  isApproved  Boolean  @default(true)
  showOnHome  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
